# CompliGuard CRE Workflow — Environment Variables
# Copy this to .env and fill in your values.
# These are used during `cre workflow simulate` only.
# For deployed workflows, use `cre secrets create`.

# Funded Sepolia private key (64-char hex, no 0x prefix)
CRE_ETH_PRIVATE_KEY=YOUR_64_CHARACTER_PRIVATE_KEY_HERE

# API keys for reserve/liability endpoints (sealed by CRE secrets)
RESERVE_API_KEY_ALL=demo-key
LIABILITY_API_KEY_ALL=demo-key
